# syntax=docker/dockerfile:1
FROM python:3.11-slim

WORKDIR /app

# Chromium for live occupancy scraping via Selenium
RUN apt-get update && apt-get install -y --no-install-recommends \
  chromium \
  chromium-driver \
  && ln -sf /usr/bin/chromium /usr/bin/google-chrome \
  && rm -rf /var/lib/apt/lists/*

COPY api/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ /src/
COPY api/ .

# Retrain inside the image so model.pkl matches the installed sklearn version.
# Credentials are passed via BuildKit secrets (not ARG/ENV) so they aren't stored in image layers.
RUN --mount=type=secret,id=supabase_url \
  --mount=type=secret,id=supabase_key \
  SUPABASE_URL="$(cat /run/secrets/supabase_url)" \
  SUPABASE_KEY="$(cat /run/secrets/supabase_key)" \
  sh -c 'cd /src && python train.py && cp model.pkl /app/model.pkl'

# fetch_data.py enables headless Chrome when GITHUB_ACTIONS is set
ENV GITHUB_ACTIONS=true

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
